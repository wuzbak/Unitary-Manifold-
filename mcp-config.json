{
  "$schema": "https://json.schemastore.org/mcp-config.json",
  "_comment": "MCP server configuration for Mythos — Unitary Manifold repository access",
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "brightdata": {
      "command": "npx",
      "args": ["-y", "@brightdata/mcp"],
      "env": {
        "BRIGHTDATA_API_TOKEN": "${BRIGHTDATA_API_TOKEN}"
      }
    }
  },
  "repository": {
    "owner": "wuzbak",
    "repo": "Unitary-Manifold-",
    "description": "The Unitary Manifold — 5D gauge-geometric framework; Walker-Pearson field equations",
    "ingest_entry_point": "MCP_INGEST.md",
    "key_files": [
      "README.md",
      "MCP_INGEST.md",
      "CITATION.cff",
      "src/core/metric.py",
      "src/core/evolution.py",
      "src/holography/boundary.py",
      "src/multiverse/fixed_point.py",
      "arxiv/main.tex",
      "zenodo/.zenodo.json"
    ]
  }
}
